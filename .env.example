# Application
NODE_ENV=development         # Runtime environment: development | test | production
PORT=3000                    # Port the HTTP server listens on

# MongoDB
MONGO_URI=mongodb://mongo:27017/ratelimitdb   # MongoDB connection string

# Redis
REDIS_URL=redis://redis:6379  # Redis connection URL for rate-limit state

# Rate Limiting Defaults (applied when client has no custom settings)
DEFAULT_RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window
DEFAULT_RATE_LIMIT_WINDOW_SECONDS=60  # Window duration in seconds

# Security
INTERNAL_API_KEY=change-this-in-prod  # Shared secret for internal endpoints (POST /clients)
BCRYPT_ROUNDS=12                      # bcrypt cost factor for API key hashing

# Logging
LOG_LEVEL=info   # Pino log level: trace | debug | info | warn | error | silent
