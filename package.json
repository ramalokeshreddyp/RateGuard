{
  "name": "my-ratelimit-service",
  "version": "1.0.0",
  "description": "Scalable API rate limiting microservice",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --runInBand",
